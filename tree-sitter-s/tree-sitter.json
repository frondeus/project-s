{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "s",
      "camelcase": "S",
      "title": "S",
      "scope": "source.s",
      "file-types": [
        "s"
      ],
      "injection-regex": "^s$",
      "class-name": "TreeSitterS"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Project S",
    "authors": [
      {
        "name": "Wojciech Polak",
        "email": "project-s@frondeus.pl"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-s"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}